{
  "version": 2,
  "builds": [
    {
      "src": "api/leads-all.js",
      "use": "@vercel/node"
    },
    {
      "src": "web_operis_completa.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/leads/(.*)",
      "dest": "/api/leads-all.js"
    },
    {
      "src": "/",
      "dest": "/web_operis_completa.html"
    },
    {
      "src": "/politica-privacidad",
      "dest": "/politica-privacidad.html"
    },
    {
      "src": "/aviso-legal",
      "dest": "/aviso-legal.html"
    },
    {
      "src": "/politica-cookies",
      "dest": "/politica-cookies.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
